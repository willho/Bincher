# Proxy-2 Configuration
# Deploy on separate machine/Docker container
# Run with: npm run proxy:2 (or manually set env vars)

# Proxy Identity
PROXY_NAME=proxy-2
PROXY_PORT=3002
OUTBOUND_IP=<YOUR_PROXY_2_IP>

# Pincher2 Coordination (optional - if not set, runs idle waiting for connection)
PINCHER2_URL=http://<PINCHER2_IP>:3000

# API Credentials (these multiply across proxy mesh for rate limits)
SHYFT_API_KEY=<YOUR_SHYFT_API_KEY_FOR_PROXY_2>
CHAINSTACK_RPC_URL=https://<YOUR_CHAINSTACK_ENDPOINT_FOR_PROXY_2>
HELIUS_API_KEY=<YOUR_HELIUS_API_KEY_FOR_PROXY_2>

# Node Environment
NODE_ENV=production
