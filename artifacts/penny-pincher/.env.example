# ============================================================
# Penny Pincher — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# In Replit, set these as Secrets (not in a .env file).

# ----- DATABASE (auto-provisioned by Replit) ---------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----- SESSION -------------------------------------------------
# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-session-secret-here

# ----- SOLANA RPC PROVIDERS ------------------------------------
# Helius: https://dashboard.helius.dev
HELIUS_API_KEY=your-helius-api-key
HELIUS_API_KEY_DEV=your-helius-dev-key        # optional, for devnet
HELIUS_API_KEY_PROD=your-helius-prod-key      # optional, for mainnet

# Chainstack: https://console.chainstack.com
CHAINSTACK_RPC_URL=https://solana-mainnet.core.chainstack.com/your-key
CHAINSTACK_API_KEY=your-chainstack-api-key    # optional

# QuickNode: https://dashboard.quicknode.com (optional, fallback RPC)
QUICKNODE_API_KEY=your-quicknode-key

# Alchemy: https://dashboard.alchemy.com (optional, fallback RPC)
ALCHEMY_API_KEY=your-alchemy-api-key

# Direct Solana RPC endpoint (optional, overrides provider selection)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ----- AI / LLM ------------------------------------------------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
# Or use Replit AI Integrations (no key needed, set via Replit integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ----- TELEGRAM BOT (optional) ---------------------------------
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# Admin codeword for privileged Telegram commands — REQUIRED if using Telegram admin
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
TELEGRAM_ADMIN_CODEWORD=your-secret-admin-codeword

# ----- EMAIL (optional) ----------------------------------------
# Resend: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# ----- TOKEN DATA PROVIDERS ------------------------------------
# Birdeye: https://birdeye.so (optional, token data)
BIRDEYE_API_KEY=your-birdeye-api-key

# Shyft: https://shyft.to (optional, on-chain data)
SHYFT_API_KEY=your-shyft-api-key

# PumpPortal: https://pumpportal.fun (optional, pump.fun trades)
PUMPPORTAL_API_KEY=your-pumpportal-api-key

# ----- NETWORK -------------------------------------------------
# "mainnet-beta" or "devnet"
NETWORK_MODE=mainnet-beta

# ----- WEBHOOK SECURITY (optional) ----------------------------
WEBHOOK_SECRET=your-webhook-secret

# ----- PROXY CONFIGURATION (optional) -------------------------
# Used when running proxy instances (proxy:1, proxy:2 scripts)
PROXY_AUTH_PASSWORD=your-proxy-password

# ----- ENCRYPTION (optional) ----------------------------------
# 32-byte hex key used to encrypt sensitive stored data (e.g. private keys at rest)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# ----- DEVELOPMENT SHORTCUTS -----------------------------------
# Set this to bypass the startup wizard during local dev / CI runs.
# The Replit artifact workflow sets this automatically.
SKIP_STARTUP_WIZARD=true
